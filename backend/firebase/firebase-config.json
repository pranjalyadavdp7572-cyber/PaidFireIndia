    },
    "facebook": {
      "enabled": true,
      "appId": "YOUR_FACEBOOK_APP_ID",
      "appSecret": "YOUR_FACEBOOK_APP_SECRET"
    },
    "apple": {
      "enabled": true,
      "teamId": "YOUR_APPLE_TEAM_ID",
