  "databaseRules": {
    "rules": {
      "players": {
        "$uid": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid"
        }
      },
      "games": {
        "$gameId": {
          ".read": true,
          ".write": "root.child('games').child($gameId).child('players').child(auth.uid).exists()"
        }
      },
      "leaderboard": {
        ".read": true,
        ".write": false
      }
    }
  },
