<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/game_bg">
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📱 App Manager"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="16dp" />
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_card"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:id="@+id/storage_used_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 Used: 2.3 GB / 4 GB"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />
        
        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progress="57"
            android:layout_marginBottom="8dp" />
        
        <TextView
            android:id="@+id/storage_total_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦 Available: 1.7 GB"
            android:textColor="@color/accent"
            android:textSize="12sp" />
    </LinearLayout>
    
    <ListView
        android:id="@+id/game_modes_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp" />
    
    <Button
        android:id="@+id/clean_cache_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🧹 Clean Cache (Save 500 MB)"
        android:textSize="14sp"
        android:padding="12dp"
        android:backgroundTint="@color/warning" />
    
</LinearLayout>
