<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/game_bg">
    
    <!-- HUD Top Bar -->
    <LinearLayout
        android:id="@+id/hud_top_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@drawable/hud_background"
        android:layout_alignParentTop="true">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:id="@+id/health_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❤️ Health: 100/100"
                android:textColor="@color/white"
                android:textSize="12sp" />
            
            <ProgressBar
                android:id="@+id/health_bar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progress="100"
                android:layout_marginTop="2dp"
                android:progressDrawable="@drawable/health_bar" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">
            
            <TextView
                android:id="@+id/ammo_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔫 Ammo: 30"
                android:textColor="@color/white"
                android:textSize="12sp" />
            
            <ProgressBar
                android:id="@+id/ammo_bar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progress="100"
                android:layout_marginTop="2dp"
                android:progressDrawable="@drawable/ammo_bar" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">
            
            <TextView
                android:id="@+id/diamond_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💎 Diamonds: 0"
                android:textColor="@color/accent"
                android:textSize="12sp" />
            
            <TextView
                android:id="@+id/speed_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚡ Speed: 1x"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
    
    <!-- Game View (3D renderer would go here) -->
    <FrameLayout
        android:id="@+id/game_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/hud_top_bar"
        android:layout_above="@id/hud_bottom_bar"
        android:background="@drawable/game_background" />
    
    <!-- HUD Bottom Bar (Stats) -->
    <LinearLayout
        android:id="@+id/hud_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@drawable/hud_background"
        android:layout_alignParentBottom="true">
        
        <TextView
            android:id="@+id/score_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Score: 0"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:gravity="center" />
        
        <TextView
            android:id="@+id/kills_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💀 Kills: 0"
            android:textColor="#FF6B6B"
            android:textSize="12sp"
            android:gravity="center" />
    </LinearLayout>
    
    <!-- Control Buttons (Bottom Right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center_horizontal|bottom"
        android:padding="8dp"
        android:layout_above="@id/hud_bottom_bar"
        android:layout_marginBottom="10dp">
        
        <Button
            android:id="@+id/shoot_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="💥"
            android:textSize="24sp"
            android:layout_margin="4dp" />
        
        <Button
            android:id="@+id/grenade_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="💣"
            android:textSize="24sp"
            android:layout_margin="4dp" />
        
        <Button
            android:id="@+id/heal_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="🏥"
            android:textSize="24sp"
            android:layout_margin="4dp" />
        
        <Button
            android:id="@+id/speed_boost_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="⚡"
            android:textSize="24sp"
            android:layout_margin="4dp" />
        
        <Button
            android:id="@+id/loot_button"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="🎁"
            android:textSize="24sp"
            android:layout_margin="4dp" />
    </LinearLayout>
    
</RelativeLayout>
